# ─────────────────────────────────────────────────────────────
# Kenya Group Joining Safaris — AI Agent Environment Variables
# ─────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your real values.
# NEVER commit .env to git — it is in .gitignore.
# ─────────────────────────────────────────────────────────────

# ── Required ──────────────────────────────────────────────────
# Get from: https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-...your-key-here...

# ── Phase 2: Knowledge base (Pinecone) ───────────────────────
# Get from: https://app.pinecone.io → API Keys
PINECONE_API_KEY=your-pinecone-api-key
PINECONE_INDEX_NAME=kenya-safari-knowledge

# ── Notification Webhook ──────────────────────────────────────
# Make.com webhook URL — receives booking alerts from the agent
NOTIFICATION_WEBHOOK_URL=https://hook.eu1.make.com/your-webhook-id

# WhatsApp API token (used by Make.com to send WhatsApp notifications)
WHATSAPP_API_TOKEN=your-whatsapp-api-token

NOTIFICATION_EMAIL=bookings@groupjoiningsafaris.com
